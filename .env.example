# =========================
# App
# =========================
APP_NAME=TaskForge API
APP_ENV=development
DEBUG=true
API_PORT=8000

# =========================
# PostgreSQL (Docker container exposed to localhost)
# =========================
POSTGRES_DB=taskforge
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://taskforge:taskforge@localhost:5432/taskforge

# =========================
# Redis (Docker container exposed to localhost)
# =========================
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0